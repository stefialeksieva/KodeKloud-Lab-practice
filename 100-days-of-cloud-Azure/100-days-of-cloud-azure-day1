Day 1: Create SSH Key Pair for Azure Virtual Machine

#Check the Resource Group
az group list -o table

#Get the RG, example in my case was "kml_rg_main-edbb50f57466404f"

#Generate a key with name "datacenter-kp"
ssh-keygen -t rsa -f ~/.ssh/datacenter-kp


#Explanation of the command:
#ssh-keygen → generates a new SSH key pair
#-t rsa → specifies RSA key type
#-f ~/.ssh/datacenter-kp → sets the key pair name to datacenter-kp
#The command creates:
#~/.ssh/datacenter-kp (private key)
#~/.ssh/datacenter-kp.pub (public key)

#Configuration of Azure env. with details. Show the Azure credentails:
showcreds

#Login
az login

az sshkey create \
  --name datacenter-kp \
  --resource-group kml_rg_main-edbb50f57466404f \
  --location eastus \
  --public-key @/home/azure-user/datacenter-kp.pub