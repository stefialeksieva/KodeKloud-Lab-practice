# Day 2: Create an Azure Virtual Machine

#Identify the existing resource group
az group list -o table

#Create an Azure VM

az vm create \
  --resource-group kml_rg_main-976cc618b4674a35 \
  --name nautilus-vm \
  --location westus \
  --image Ubuntu2404 \
  --size Standard_B1s \
  --admin-username azureuser \
  --generate-ssh-keys \
  --os-disk-size-gb 30 \
  --storage-sku Standard_LRS

#Get the IP

az vm show \
  --resource-group kml_rg_main-976cc618b4674a35 \
  --name nautilus-vm \
  -d --query publicIps -o tsv

#Establish an SSH connection
ssh azureuser@<PUBLIC_IP>