Day 19: Install and Configure Web Application

#Establish an SSH connection to the app server
ssh user@app-server-name

#Switch user to root
sudo su - 

#Install PHP‑FPM 8.1 and configure socket
yum install -y epel-release
yum install -y https://rpms.remirepo.net/enterprise/remi-release-7.rpm
yum-config-manager --disable 'remi-php*'
yum-config-manager --enable remi-php81
yum install -y php php-fpm php-cli php-mysqlnd
# Create the socket directory
mkdir -p /var/run/php-fpm

#Configure PHP‑FPM to use that socket
vim /etc/php-fpm.d/www.conf

#You need to change the following lines to:
listen = /var/run/php-fpm/default.sock
listen.owner = nginx
listen.group = nginx
listen.mode = 0660
user = nginx
group = nginx

#Start and enable the service
systemctl enable php-fpm
systemctl start php-fpm

#Configure Nginx to work with PHP‑FPM
vim /etc/nginx/conf.d/default.conf

#Content
server {
    listen       8096;
    listen       [::]:8096;
    server_name  _;
    root         /var/www/html;

    include /etc/nginx/default.d/*.conf;

    error_page 404 /404.html;
    location = /404.html { }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html { }

    location ~ \.php$ {
        fastcgi_pass   unix:/var/run/php-fpm/default.sock;
        fastcgi_index  index.php;
        include        fastcgi_params;
        fastcgi_param  SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }
}

#Test Nginx config
nginx -t

#Restart Nginx
systemctl restart nginx

#Test from jump-host
curl http://app-server-name:8096/index.php
