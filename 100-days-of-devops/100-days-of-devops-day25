Day 25: Git Merge Branches

#Establish an SSH connection to the server
ssh user@server

#Switch the user to root
sudo su -

#Navigate to the repository directory
cd /usr/src/kodekloudrepos/demo

#Ensure you are on the master branch
git checkout master

#Create the new branch datacenter
git checkout -b datacenter

#Copy the required file into the repo
cp /tmp/index.html .

# Add and commit the file
git add index.html
git commit -m "Add index.html for datacenter branch"

#Push the new branch to origin
git push origin datacenter

#Merge the branch back into master
git checkout master
git merge datacenter

#Push the updated master branch
git push origin master
