#!/bin/bash

# Variables
SRC_DIR="/var/www/html/official"
BACKUP_DIR="/backup"
ARCHIVE_NAME="xfusioncorp_official.zip"
REMOTE_USER="clint"
REMOTE_HOST="backup-server"
REMOTE_DIR="/backup"

# Create local backup archive
zip -r ${BACKUP_DIR}/${ARCHIVE_NAME} ${SRC_DIR}

# Copy archive to Nautilus Backup Server
scp ${BACKUP_DIR}/${ARCHIVE_NAME} ${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_DIR}/


#Make it executable
chmod +x /scripts/ecommerce_backup.sh

# Test the script
/scripts/ecommerce_backup.sh
