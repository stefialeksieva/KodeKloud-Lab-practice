#Exit and Save

#Encrypt it
ansible-vault encrypt ~/playbooks/secrets/passwords.yml

#Create the playbook: ~/playbooks/add_users.yml with the content:
vim ~/playbooks/add_users.yml

---
- name: Create users and groups for onboarding
  hosts: stapp02
  become: yes

  vars_files:
    - data/users.yml
    - secrets/passwords.yml

  tasks:

    - name: Ensure groups exist
      group:
        name: "{{ item }}"
        state: present
      loop:
        - developers
        - admins

    - name: Create developer users
      user:
        name: "{{ item }}"
        group: developers
        home: "/var/www"
        password: "{{ dev_password_plain | password_hash('sha512', 'salt1234') }}"
        state: present
      loop: "{{ developers }}"

    - name: Create admin users
      user:
        name: "{{ item }}"
        group: admins
        groups: wheel
        append: yes
        password: "{{ admin_password_plain | password_hash('sha512', 'salt1234') }}"
        state: present
      loop: "{{ admins }}"

#Veirfy

#Navigate to the correct folder
cd ~/playbooks

#Run ansible playbook
ansible-playbook -i inventory add_users.yml
