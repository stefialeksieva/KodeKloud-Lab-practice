#Deploy Pods in Kubernetes Cluster

vim pod-nginx.yaml

#Paste in the pod-nginx.yaml file the following code

apiVersion: v1
kind: Pod
metadata:
  name: pod-nginx
  labels:
    app: nginx_app
spec:
  containers:
    - name: nginx-container
      image: nginx:latest

#Apply the manifest

kubectl apply -f pod-nginx.yaml

#Verify the pod

kubectl get pods
