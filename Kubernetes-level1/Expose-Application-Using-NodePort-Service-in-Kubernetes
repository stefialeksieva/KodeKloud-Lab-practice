#Create the NodePort Service with content
vim nginx-service.yaml

apiVersion: v1
kind: Service
metadata:
  name: nginx-service
spec:
  type: NodePort
  selector:
    app: nginx_app
    type: front-end
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30080

#Save and exit

#Apply
kubectl apply -f nginx-service.yaml

#Verify
kubectl get svc nginx-service

#Test access from jump-host
curl http://localhost:30080
