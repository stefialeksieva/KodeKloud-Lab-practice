#Create ReplicaSet YAML 
vim nginx-replicaset.yaml

#Content
apiVersion: apps/v1
kind: ReplicaSet
metadata:
  name: nginx-replicaset
  labels:
    app: nginx_app
    type: front-end
spec:
  replicas: 4
  selector:
    matchLabels:
      app: nginx_app
      type: front-end
  template:
    metadata:
      labels:
        app: nginx_app
        type: front-end
    spec:
      containers:
        - name: nginx-container
          image: nginx:latest

#Save and exit.

#Apply the ReplicaSet
kubectl apply -f nginx-replicaset.yaml

#Verify the ReplicaSet and pods
kubectl get rs
kubectl get pods -l app=nginx_app
