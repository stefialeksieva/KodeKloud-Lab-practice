#Create the pod using a YAML manifest (file with content)
vim httpd-pod.yaml

#Content
apiVersion: v1
kind: Pod
metadata:
  name: httpd-pod
spec:
  containers:
    - name: httpd-container
      image: httpd:latest
      resources:
        requests:
          memory: "15Mi"
          cpu: "100m"
        limits:
          memory: "20Mi"
          cpu: "100m"

#Save and exit

#Apply the manifest
kubectl apply -f httpd-pod.yaml

#Verify
kubectl get pod httpd-pod
