#Generate YAML from kubectl (the fastest way to get a working template)
#You can generate a YAML skeleton using --dry-run=client -o yaml
#Example for a Deployment
kubectl create deployment myapp --image=nginx --dry-run=client -o yaml
#Example for a pod
kubectl run mypod --image=nginx --restart=Never --dry-run=client -o yaml

#Use kubectl api-resources to discover object types
kubectl api-resources

#Use kubectl get <resource> -o yaml to see real examples
#If you already have a resource running
kubectl get deployment nginx -o yaml

