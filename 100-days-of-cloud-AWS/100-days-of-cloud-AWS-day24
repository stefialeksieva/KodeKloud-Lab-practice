Day 24: Setting Up an Application Load Balancer for an EC2 Instance

#Set region
aws configure set default.region us-east-1

#Create the ALB security group (public HTTP)
SG_ID=$(aws ec2 create-security-group \
  --group-name nautilus-sg \
  --description "Allow HTTP" \
  --vpc-id $(aws ec2 describe-vpcs --query "Vpcs[0].VpcId" --output text) \
  --query 'GroupId' --output text)

#Allow inbound HTTP
aws ec2 authorize-security-group-ingress \
  --group-id $SG_ID \
  --protocol tcp \
  --port 80 \
  --cidr 0.0.0.0/0

#Get the EC2 instance ID and subnet
INSTANCE_ID=$(aws ec2 describe-instances \
  --filters "Name=tag:Name,Values=nautilus-ec2" \
  --query "Reservations[0].Instances[0].InstanceId" \
  --output text)

SUBNET1=$(aws ec2 describe-instances \
  --instance-ids $INSTANCE_ID \
  --query "Reservations[0].Instances[0].SubnetId" \
  --output text)

#Create the Target Group
TG_ARN=$(aws elbv2 create-target-group \
  --name nautilus-tg \
  --protocol HTTP \
  --port 80 \
  --target-type instance \
  --vpc-id $(aws ec2 describe-vpcs --query "Vpcs[0].VpcId" --output text) \
  --query "TargetGroups[0].TargetGroupArn" \
  --output text)

#Register the EC2 instance
aws elbv2 register-targets \
  --target-group-arn $TG_ARN \
  --targets Id=$INSTANCE_ID

#Get the two subnets which are required
SUBNETS=$(aws ec2 describe-subnets \
  --query "Subnets[*].SubnetId" \
  --output text)

#Create the Application Load Balancer
ALB_ARN=$(aws elbv2 create-load-balancer \
  --name nautilus-alb \
  --subnets $SUBNETS \
  --security-groups $SG_ID \
  --query "LoadBalancers[0].LoadBalancerArn" \
  --output text)

#Create Listener route from ALB:80 to TG:80
aws elbv2 create-listener \
  --load-balancer-arn $ALB_ARN \
  --protocol HTTP \
  --port 80 \
  --default-actions Type=forward,TargetGroupArn=$TG_ARN

#Get EC2 security group allow ALB to EC2
EC2_SG=$(aws ec2 describe-instances \
  --instance-ids $INSTANCE_ID \
  --query "Reservations[0].Instances[0].SecurityGroups[0].GroupId" \
  --output text)

#Allow inbound HTTP from ALB SG only:
aws ec2 authorize-security-group-ingress \
  --group-id $EC2_SG \
  --protocol tcp \
  --port 80 \
  --source-group $SG_ID
