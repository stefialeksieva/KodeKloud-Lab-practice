Day 15: Create Volume Snapshot

#Get volume ID
aws ec2 describe-volumes \
  --filters "Name=tag:Name,Values=datacenter-vol" \
  --region us-east-1 \
  --query "Volumes[].VolumeId" \
  --output text

#Create the snapshot
aws ec2 create-snapshot \
  --volume-id vol-xxxxxxxx \
  --description "datacenter Snapshot" \
  --tag-specifications 'ResourceType=snapshot,Tags=[{Key=Name,Value=datacenter-vol-ss}]' \
  --region us-east-1

#Verify snapshot status until it is completed
aws ec2 describe-snapshots \
  --filters "Name=tag:Name,Values=datacenter-vol-ss" \
  --region us-east-1 \
  --query "Snapshots[].SnapshotId" \
  --output text

aws ec2 describe-snapshots \
  --snapshot-ids <your-snapshot-id> \
  --region us-east-1 \
  --query "Snapshots[].State" \
  --output text
